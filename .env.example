# ============================================================
# LOCAL DEVELOPMENT
# ============================================================

# PayloadCMS URL — point to local backend
API_URL=http://localhost:3000

# Webhook secret — only needed if testing on-demand revalidation locally
PAYLOAD_WEBHOOK_SECRET=


# ============================================================
# CI BUILD — GitHub Actions secrets
# Set in: GitHub repo → Settings → Secrets and variables → Actions
# ============================================================
#
# TAILSCALE_OAUTH_CLIENT_ID   OAuth client ID (tailscale.com/admin/settings/oauth)
# TAILSCALE_OAUTH_SECRET      OAuth client secret (same page)
#                             OAuth clients don't expire — preferred over auth keys for CI
#                             Requires a tag:ci ACL tag defined in Tailscale policy
#
# TAILSCALE_IP                Droplet's Tailscale IP  (`tailscale ip -4` on Droplet)
# PAYLOAD_WEBHOOK_SECRET      Baked into compiled bundle at build time
# DROPLET_SSH_KEY             Private key for SSH/rsync access to Droplet
# DROPLET_HOST_KEY            Droplet's known_hosts entry  (ssh-keyscan output)
# DROPLET_SSH_PORT            SSH port on Droplet
# DROPLET_USER                SSH user on Droplet
# DROPLET_HOST                Droplet's public IP or hostname


# ============================================================
# DROPLET RUNTIME
# No .env file needed. PORT is passed inline to PM2 at deploy time.
# All other vars are baked into the compiled bundle during build.
# ============================================================
